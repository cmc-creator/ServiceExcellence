{
  "name": "service-excellence-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "npm --prefix backend install && npm --prefix backend run prisma:generate",
    "dev": "concurrently -k -n FRONTEND,BACKEND \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "http-server . -p 3000 -c-1",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "http-server": "^14.1.1"
  }
}
