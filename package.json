{
  "name": "service-excellence-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "npm --prefix \"%npm_package_json%\\..\\backend\" install && npm --prefix \"%npm_package_json%\\..\\backend\" run prisma:generate",
    "dev": "concurrently -k -n FRONTEND,BACKEND \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "http-server \"%npm_package_json%\\..\" -p 3000 -c-1",
    "dev:backend": "npm --prefix \"%npm_package_json%\\..\\backend\" run dev",
    "start:backend": "npm --prefix \"%npm_package_json%\\..\\backend\" run start",
    "smoke:backend": "pwsh -ExecutionPolicy Bypass -File \"%npm_package_json%\\..\\scripts\\smoke-backend.ps1\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "http-server": "^14.1.1"
  }
}
